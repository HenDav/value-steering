#!/bin/bash
#SBATCH --job-name=vs-canonical
#SBATCH --partition=llm,normal,msc
#SBATCH --gres=gpu:a100:1
#SBATCH --time=18:00:00
#SBATCH --cpus-per-task=8
#SBATCH --mem=160G
#SBATCH --output=train_canonical.%j.out
# CANONICAL scalar value head: decode-matched, on ALL prompts, with SPP continuations
# generated + judge-labeled each (data augmentation). Clean scalar pipeline (decode_extract +
# train_value_head), vLLM judge, conformal calibration. Writes trained/canonical/.
set -e
echo "=== node: $(hostname)  job: ${SLURM_JOB_ID} ==="
nvidia-smi --query-gpu=name,memory.total,memory.free --format=csv

source ${CONDA_BASE:-$HOME/miniconda3}/etc/profile.d/conda.sh
export TMPDIR=${TMPDIR:-${VS_SCRATCH:-/tmp/$USER}/tmp}
export PIP_CACHE_DIR=${PIP_CACHE_DIR:-${VS_SCRATCH:-/tmp/$USER}/.cache/pip}
mkdir -p "$TMPDIR" "$PIP_CACHE_DIR"
export PYTHONNOUSERSITE=1   # ARM: ignore ~/.local x86 wheels; set BEFORE pip so the env is self-complete
ENVDIR=${VS_SCRATCH:-/tmp/$USER}/envs/vsteer-$(hostname -s)
if [ ! -f "$ENVDIR/.complete" ]; then
  echo "=== clean build at $ENVDIR (full closure; cu128 ARM torch) ==="
  rm -rf "$ENVDIR"; conda create -y -p "$ENVDIR" python=3.12; conda activate "$ENVDIR"
  cd ${VALUE_STEER_ROOT:-$(git rev-parse --show-toplevel)}
  pip install torch==2.10.0 torchvision==0.25.0 torchaudio==2.10.0 --index-url https://download.pytorch.org/whl/cu128
  pip install vllm==0.19.1
  pip install -e ".[dev,train]"
  touch "$ENVDIR/.complete"
else
  conda activate "$ENVDIR"; cd ${VALUE_STEER_ROOT:-$(git rev-parse --show-toplevel)}
  pip install -e ".[dev,train]" -q
fi
pip install -q datasets
pip check || echo "WARNING: pip check reported unmet deps above"
export VLLM_ENABLE_V1_MULTIPROCESSING=0 VLLM_HOST_IP=127.0.0.1 TOKENIZERS_PARALLELISM=false
export HF_HOME=${HF_HOME:-${VS_SCRATCH:-/tmp/$USER}/huggingface}

ROOT=${VALUE_STEER_ROOT:-$(git rev-parse --show-toplevel)}
MODEL=${VALUE_STEER_MODEL:-mistralai/Mistral-7B-Instruct-v0.3}
JUDGE=${JUDGE_MODEL:-NousResearch/Meta-Llama-3.1-8B-Instruct}
CACHE=${VS_SCRATCH:-/tmp/$USER}/canonical.cache
PROMPTS=$ROOT/data/hh_train_full.jsonl
N=${N_PROMPTS:-1000000}            # "all": prep caps at the deduped split size
S=${SPP:-4}                        # continuations generated + tagged per prompt
OUT=$ROOT/trained/canonical/value_head.bin

echo "=== prep ${HH_SUBSET:-harmless-base} prompts (cap $N) ==="
python - "$PROMPTS" "$N" "${HH_SUBSET:-harmless-base}" <<'PY'
import json, sys
from datasets import load_dataset
out, n, subset = sys.argv[1], int(sys.argv[2]), sys.argv[3]
def first_human(t):
    parts = t.split("\n\nHuman:")
    return (parts[1].split("\n\nAssistant:")[0]).strip() if len(parts) > 1 else None
ds = load_dataset("Anthropic/hh-rlhf", data_dir=subset, split="train")
seen, c = set(), 0
with open(out, "w") as w:
    for ex in ds:
        p = first_human(ex["chosen"])
        if p and p not in seen:
            seen.add(p); w.write(json.dumps({"prompt": p}) + "\n"); c += 1
        if c >= n: break
print(f"# wrote {c} prompts ({subset}) -> {out}", flush=True)
PY

echo "########## 1. decode-cache GEN (S=$S samples/prompt, VFD never-intervene + dump) ##########"
python scripts/decode_extract.py --phase gen --cache-dir "$CACHE" --model "$MODEL" \
  --head "$ROOT/trained/safety_decode/value_head.bin" --source "$PROMPTS" --n "$N" \
  --samples-per-prompt "$S" --max-tokens 128 --gen-chunk 256 --max-num-seqs 16 --util 0.45

echo "########## 2. vLLM-judge LABEL + split train/val ##########"
python scripts/decode_extract.py --phase label --cache-dir "$CACHE" --model "$MODEL" \
  --judge-model "$JUDGE" --val-split 0.1

echo "########## 3. TRAIN scalar head + conformal calibrate ##########"
python scripts/train_value_head.py --phase train --out "$OUT" --cache-dir "$CACHE" \
  --domain safety_canonical --epochs 10 --batch-size 128 --lr 1e-4 --warmup-frac 0.1 \
  --num-workers 4 --calibrate

echo "########## 4. assemble local upload-ready artifact (model card + load snippet) ##########"
python - "$OUT" "$S" "$N" "${HH_SUBSET:-harmless-base}" "$MODEL" <<'PY'
import json, os, sys
out, S, N, subset, model = sys.argv[1:6]
d = os.path.dirname(out)
meta = json.load(open(out + ".meta.json"))
thr = meta.get("threshold"); m = meta.get("meta", {})
card = f"""---
license: apache-2.0
base_model: {model}
tags: [value-head, safety, vfd, value-steering]
---

# Canonical safety value head (decode-matched)

A scalar value head for **Value-Filtered Decoding (VFD)** / dynamic abstention with
[value-steer](https://github.com/HenDav/value-steering) on `{model}`. Predicts per-token P(undesirable) from the
backbone's final-layer **post-norm** hidden state (the exact tensor `lm_head` consumes), fp32.

## Training
- Data: hh-rlhf **{subset}** prompts, **{S} sampled continuations per prompt**, generated by the
  base model and **judge-labeled** (Llama-3.1-8B) for safety. Decode-matched features (the hidden
  VFD actually scores at inference), not prefill.
- n_train: {m.get('n_train')} | recipe: {m.get('recipe')} | epochs: {m.get('epochs')}
- **Conformal-calibrated threshold (tau=0.05): {round(thr,4) if thr else None}**

## Files
- `value_head.bin` — state dict of the head MLP (Linear(H,H)->Tanh->Linear(H,H)->ReLU->Linear(H,1), fp32)
- `value_head.bin.meta.json` — feature spec + calibrated threshold + training metadata

## Use (vLLM plugin)
```bash
vllm serve {model} --worker-cls value_steer.worker.ValueSteerWorker \\
  --additional-config '{{"vfd": {{"enabled": true, "value_head_path": "value_head.bin", "threshold": 0.3}}}}'
```
Steer at **threshold 0.3**; the calibrated conformal threshold above is conservative and barely intervenes.
```python
from value_steer.value_probe import load_value_head
head = load_value_head("value_head.bin", hidden_size=4096)  # device defaults to cuda; p_unsafe = head.p(hidden)
```
"""
open(os.path.join(d, "README.md"), "w").write(card)
print(f"[OK] wrote {d}/README.md (model card)", flush=True)
print(f"[OK] upload-ready artifact dir: {d}  (push with: huggingface-cli upload <repo> {d})", flush=True)
PY

echo "=== cache: $(du -sh "$CACHE" 2>/dev/null | cut -f1) ==="
echo "=== DONE job ${SLURM_JOB_ID}: canonical head + card -> $(dirname "$OUT") ==="
